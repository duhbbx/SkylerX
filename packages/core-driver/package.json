  },
  "peerDependencies": {
    "@elastic/elasticsearch": "^8",
    "ioredis": "^5",
    "mongodb": "^6"
  },
  "peerDependenciesMeta": {
    "@elastic/elasticsearch": { "optional": true },
    "ioredis": { "optional": true },
    "mongodb": { "optional": true }
  },
  "devDependencies": {
    "@types/mssql": "^9.1.7",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
