{
  "name": "@db-tool/desktop",
  "version": "0.1.1",
  "private": true,
  "description": "数据库管理工具 - 桌面端 (Electron + Vue3)",
  "main": "./out/main/index.js",
  "author": {
    "name": "duhbbx",
    "email": "duhbbx@gmail.com"
  },
  "homepage": "https://github.com/duhbbx/SkylerX",
  "repository": {
    "type": "git",
    "url": "https://github.com/duhbbx/SkylerX.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "start": "electron-vite preview",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "rebuild:native": "electron-builder install-app-deps",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "better-sqlite3": "^11.8.1",
    "electron-updater": "^6.3.9",
    "ioredis": "^5.4.1",
    "mongodb": "^6.10.0",
    "mssql": "^11.0.1",
    "mysql2": "^3.11.5",
    "pg": "^8.13.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@db-tool/core-driver": "workspace:*",
    "@db-tool/shared-types": "workspace:*",
    "@db-tool/ui": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/ssh2": "^1.15.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "monaco-editor": "^0.52.2",
    "sql-formatter": "^15.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.0"
  }
}
