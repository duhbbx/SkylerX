# 文档站 deploy 目标 (本地一键 `bash apps/website/deploy.sh` 用).
#
# 用法: cp apps/website/.env.deploy.example apps/website/.env.deploy
#       填入下面变量后 deploy.sh 自动 source 一下不必手 export.
#
# .env.deploy 已 gitignored, 真实值不会进 git.

SKYLERX_DEPLOY_HOST=
SKYLERX_DEPLOY_USER=root
SKYLERX_DEPLOY_WEBROOT=
SKYLERX_DEPLOY_DOMAIN=

# 可选: 没配 ssh-key 时走 sshpass + 密码
# SSHPASS=
