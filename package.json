{
  "name": "skylerx",
  "version": "0.0.0",
  "private": true,
  "description": "SkylerX — 跨平台数据库管理工具（桌面端开源 + Web 端独立部署）",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:desktop": "pnpm --filter @db-tool/desktop dev",
    "build:desktop": "pnpm --filter @db-tool/desktop build",
    "build:packages": "pnpm --filter \"./packages/**\" build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "ignoredOptionalDependencies": [
      "cpu-features"
    ]
  }
}
